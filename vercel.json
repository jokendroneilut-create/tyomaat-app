{
  "crons": [
    {
      "path": "/api/digests",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/agent/run",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/tic/discovery/collect",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/tic/discovery/run?stage=process",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/admin/scan-duplicates?mode=incremental",
      "schedule": "0 4 * * 1"
    },
    {
      "path": "/api/admin/auto-complete-projects",
      "schedule": "0 5 * * *"
    }
  ]
}